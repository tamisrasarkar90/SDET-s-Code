/*
Problem Description: Given a string s, remove duplicate letters so that every letter appears once and only once. You must make sure your result is the smallest in lexicographical order among all possible results.
Example 1:
Input: s = "bcabc"
Output: "abc"
Example 2:
Input: s = "cbacdcbc"
Output: "acdb"
Constraints:
1 <= s.length <= 104
s consists of lowercase English letters.
 
Note: This question is the same as 1081: https://leetcode.com/problems/smallest-subsequence-of-distinct-characters/

*/
class Solution {
    public String removeDuplicateLetters(String s) 
    {
        boolean[] charPresent=new boolean[26];
        Arrays.fill(charPresent,false);
        int[] lastIndex=new int[26];
        Arrays.fill(lastIndex,-1);
        for(int i=0;i<s.length();i++)
        {
              lastIndex[s.charAt(i)-'a']=i;
        }
        StringBuilder result=new StringBuilder();
        for(int i=0;i<s.length();i++)
        {
           char ch=s.charAt(i);
           int idx=ch-'a';
           if(charPresent[idx])
           {
             continue;
           }

 while (result.length() > 0 && ch < result.charAt(result.length() - 1) && lastIndex[result.charAt(result.length() - 1) - 'a'] > i) {
        charPresent[result.charAt(result.length() - 1) - 'a'] = false;
        result.deleteCharAt(result.length() - 1);
    }
     result.append(ch);
     charPresent[idx]=true;
    }
     return result.toString();
    }
}
